# ─── ChurnAI — Environment Variables ────────────────────────────────────────
# Copy this file to `.env` and fill in your own values.
# NEVER commit the real .env file — it is git-ignored.

# ─── Claude / Anthropic (optional) ───────────────────────────────────────────
# Without a key the pipeline still runs end-to-end in "demo mode"
# (deterministic Python agents), but the CEO + Communication reasoning
# layers powered by Claude are disabled.
ANTHROPIC_API_KEY=sk-ant-...

# IDs of the Claude Managed Agents (see setup_agents.py).
# Optional — only needed if you deploy hosted agents instead of the
# inline prompts in backend/agents/ceo_agent.py.
CLAUDE_CEO_AGENT_ID=
CLAUDE_COMMS_AGENT_ID=
CLAUDE_ANALYST_AGENT_ID=
CLAUDE_ENVIRONMENT_ID=

# ─── Stripe (optional — mock data used if empty) ─────────────────────────────
STRIPE_SECRET_KEY=

# ─── Email delivery (optional — emails simulated in logs if empty) ───────────
SENDGRID_API_KEY=
FROM_EMAIL=noreply@yourdomain.com

# ─── PostgreSQL (required) ───────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://churnai:churnai@localhost:5432/churnai

# ─── Redis (optional — dashboard caching) ────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── API authentication (optional — open in dev if empty) ────────────────────
# When set, every sensitive endpoint requires the `X-API-Key` header.
API_KEY=

# ─── App settings ────────────────────────────────────────────────────────────
PRODUCT_NAME=ChurnAI
APP_ENV=development
LOG_LEVEL=INFO
